# vi: set ft=yaml :
# Group variables for local development environment
# Supports macOS and Linux with XDG Base Directory Specification compliance

#
# Core Dotfiles Configuration
#

# XDG Base Directory Specification paths
xdg_config_home: "{{ ansible_env.XDG_CONFIG_HOME | default(ansible_env.HOME + '/.config') }}"
xdg_data_home: "{{ ansible_env.XDG_DATA_HOME | default(ansible_env.HOME + '/.local/share') }}"
xdg_cache_home: "{{ ansible_env.XDG_CACHE_HOME | default(ansible_env.HOME + '/.cache') }}"
xdg_state_home: "{{ ansible_env.XDG_STATE_HOME | default(ansible_env.HOME + '/.local/state') }}"

# Dotfiles repository location
dotfiles_user_home: "{{ ansible_env.HOME }}"
dotfiles_home: "{{ dotfiles_user_home }}/dotfiles"
dotfiles_repo_url: "https://github.com/{{ ansible_user_id }}/dotfiles.git"

#
# Personal Information (CUSTOMIZE THESE!)
#

# Name used in Git commits and other places
full_name: "Your Full Name"  # CHANGE THIS

# Git configuration
git_user: "yourusername"     # CHANGE THIS to your GitHub username
git_email: "your.email@example.com"  # CHANGE THIS to your Git email

#
# System Configuration
#

# Package management
package_update: yes
package_upgrade: no  # Set to yes if you want automatic upgrades during setup

# Environment detection
gui_environment: "{{ ansible_env.DISPLAY is defined or ansible_os_family == 'Darwin' }}"

# Platform-specific feature toggles
icloud_enabled: "{{ ansible_os_family == 'Darwin' }}"  # Only enable on macOS

#
# Shell Configuration
#

# Zsh configuration
zsh_prezto: true            # Enable Prezto framework
set_zsh_as_default: true    # Set zsh as default shell

#
# Editor Configuration
#

# Vim configuration
vim_install_plugins: false  # Set to true to auto-install vim plugins during setup

#
# Package Lists - macOS (Homebrew)
#

# Command-line utilities installed via Homebrew
mac_homebrew_packages:
  - curl
  - wget
  - jq
  - git
  - vim
  - zsh
  - ripgrep              # Fast grep alternative (rg)
  - fd                   # Fast find alternative
  - bat                  # Cat with syntax highlighting
  - eza                  # Modern ls replacement
  - htop
  - bottom               # System monitor
  - tree
  - terminal-notifier    # Notifications from command line
  - gh                   # GitHub CLI
  - diff-so-fancy        # Better git diffs
  - tldr                 # Simplified man pages
  - watch
  - imagemagick          # Image processing
  - qrtool               # QR code generator

# GUI applications installed via Homebrew Cask
mac_cask_packages:
  # Development
  - visual-studio-code
  - iterm2
  
  # Browsers
  - firefox
  - google-chrome
  
  # Productivity
  - obsidian             # Note-taking
  - 1password            # Password manager
  
  # Utilities
  - appcleaner
  - the-unarchiver
  - keka                 # Archive utility
  
  # Media
  - vlc
  - spotify
  
  # Communication
  - slack
  - discord
  - zoom

# Mac App Store applications (use `mas search <app>` to find IDs)
mac_mas_packages:
  - {"id": 409203825, "name": "Numbers"}
  - {"id": 409201541, "name": "Pages"}
  - {"id": 409183694, "name": "Keynote"}

#
# Package Lists - Linux
#

# Packages for Debian/Ubuntu systems
debian_packages:
  - curl
  - wget
  - git
  - vim
  - zsh
  - ripgrep
  - fd-find
  - bat
  - htop
  - tree
  - build-essential
  - software-properties-common
  - apt-transport-https
  - ca-certificates
  - gnupg
  - lsb-release

# Packages for Arch Linux systems  
arch_packages:
  - curl
  - wget
  - git
  - vim
  - zsh
  - ripgrep
  - fd
  - bat
  - htop
  - tree
  - base-devel

# Snap packages (cross-platform Linux)
snap_packages:
  - code
  - firefox
  - discord

# Flatpak packages (cross-platform Linux)
flatpak_packages:
  - org.mozilla.firefox
  - com.spotify.Client
  - org.signal.Signal

#
# Development Tools
#

# Python tools (installed via uv/pip)
python_tools:
  - ipython
  - ipdb
  - black
  - ruff
  - pytest

# Node.js global packages
node_packages:  
  - typescript
  - prettier
  - eslint

#
# Directory Structure
#

# Directories to create in user's home
user_directories:
  - "{{ xdg_config_home }}"
  - "{{ xdg_data_home }}"
  - "{{ xdg_cache_home }}"
  - "{{ xdg_state_home }}"
  - "{{ dotfiles_user_home }}/bin"
  - "{{ dotfiles_user_home }}/projects"
  - "{{ dotfiles_user_home }}/tmp"

#
# Application-Specific Configuration
#

# Applications that support XDG Base Directory Specification
xdg_compliant_apps:
  vim:
    config_dir: "{{ xdg_config_home }}/vim"
    data_dir: "{{ xdg_data_home }}/vim"
    state_dir: "{{ xdg_state_home }}/vim"
  zsh:
    config_dir: "{{ xdg_config_home }}/zsh"
    data_dir: "{{ xdg_data_home }}/zsh"
    state_dir: "{{ xdg_state_home }}/zsh"
    cache_dir: "{{ xdg_cache_home }}/zsh"

#
# Feature Flags
#

# Optional features that can be enabled/disabled
features:
  install_development_tools: true
  install_media_tools: true
  install_communication_tools: true
  setup_ssh_config: true
  setup_git_config: true
  install_fonts: true
  setup_cron_jobs: false

#
# Platform-Specific Overrides
#

# Variables that change based on the operating system
platform_vars:
  Darwin:
    package_manager: homebrew
    shell_path: /opt/homebrew/bin/zsh
    homebrew_prefix: /opt/homebrew
  Debian:
    package_manager: apt
    shell_path: /usr/bin/zsh
  Archlinux:
    package_manager: pacman
    shell_path: /usr/bin/zsh
